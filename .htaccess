# WizMedik Frontend SPA .htaccess (safe)

AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  # Normalize compressed extensions so .gz/.br are treated as encodings,
  # not as final MIME type (application/x-gzip).
  RemoveType .gz
  RemoveType .br
  AddEncoding gzip .gz
  AddEncoding br .br

  AddType text/html .html .html.gz .html.br
  AddType text/javascript .js .mjs
  AddType text/javascript .js.gz .mjs.gz .js.br .mjs.br
  AddType text/css .css .css.gz .css.br
  AddType application/json .json .json.gz .json.br
  AddType image/svg+xml .svg .svg.gz .svg.br
</IfModule>

<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(self), microphone=(), camera=()"

  Header set Vary "Accept-Encoding"
  Header unset ETag

  <FilesMatch "\.(js|mjs|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set X-Robots-Tag "noindex, nofollow"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|avif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <Files "sw.js">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </Files>

  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "^sitemap(?:-[A-Za-z0-9-]+)?\.xml$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

FileETag None

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  AddOutputFilterByType DEFLATE font/ttf font/otf font/opentype
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject

  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteOptions AllowNoSlash
  RewriteBase /

  # Never redirect sitemap XML outside this host.
  # If file exists locally, serve it directly.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^sitemap(?:-[A-Za-z0-9-]+)?\.xml$ - [L,NC]

  # Force legacy compressed asset URLs back to canonical files.
  # Prevents module load failures from stale HTML/SW caches referencing *.js.gz/*.js.br.
  RewriteRule ^assets/(.+)\.(js|mjs|css|json|svg)\.(gz|br)$ /assets/$1.$2 [R=302,L,NC]

  # Missing static assets must return 404 (never SPA index.html).
  RewriteCond %{REQUEST_URI} ^/assets/ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Missing sitemap files must return 404 (never SPA index.html).
  RewriteCond %{REQUEST_URI} ^/sitemap(?:-[A-Za-z0-9-]+)?\.xml$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Serve key top-level prerendered listing routes directly to their static
  # route index.html. This avoids Plesk/Apache edge cases where an existing
  # directory like /blog can still resolve to 404 instead of /blog/index.html.
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(blog|gradovi|about|pitanja|domovi-njega|doktori|klinike|laboratorije|apoteke|banje)$ $1/index.html [L,NC]

  # Canonicalize trailing slash variants to the slashless public URL.
  # This reduces duplicate crawl paths like /grad/bihac/ vs /grad/bihac.
  RewriteCond %{REQUEST_URI} !^/$
  RewriteCond %{REQUEST_URI} .+/$
  RewriteCond %{REQUEST_URI} !^/assets(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !\.[A-Za-z0-9]{1,8}/?$ [NC]
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Serve prerendered public blog detail pages directly when their static
  # route file exists. This must run before the "missing blog detail => 404"
  # guard because some Apache/Plesk setups do not resolve REQUEST_FILENAME
  # consistently for nested virtual routes.
  RewriteCond %{DOCUMENT_ROOT}/blog/$1/index.html -f
  RewriteRule ^blog/([^/]+)$ blog/$1/index.html [L,NC]

  # If a public blog detail page is missing from the static prerender output,
  # return 404 instead of falling through to the homepage shell with a root canonical.
  # Use THE_REQUEST so internal rewrites like /blog -> /blog/index.html are not blocked.
  RewriteCond %{THE_REQUEST} \s/+blog/[^/\s]+/?(?:[\s?]|$) [NC]
  RewriteCond %{REQUEST_URI} !^/blog/editor(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !^/blog/index\.html$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}/index.html !-f
  RewriteRule ^ - [R=404,L]

  # Serve prerendered route directories without external 301 to trailing slash.
  # Resolve directly against the on-disk route index.html instead of relying only
  # on Apache's directory detection, which can be inconsistent on some Plesk setups.
  # Example: /specijalnost/ginekologija/histeroskopija -> /.../index.html (internal)
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{REQUEST_URI} !^/assets(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !\.[A-Za-z0-9]{1,8}$ [NC]
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+)$ /$1/index.html [L]

  # Existing files/directories are served as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback to static SPA shell.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>
