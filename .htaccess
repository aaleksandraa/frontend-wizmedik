# ==========================================================
# WizMedik Frontend (SPA) - Apache .htaccess (safe modules)
# Domain: wizmedik.com
# Backend API: api.wizmedik.com (no proxy rewrite here)
# ==========================================================

<IfModule mod_negotiation.c>
  # Prevent Apache content negotiation from resolving .js to .js.gz/.js.br
  Options -MultiViews
</IfModule>

# Charset
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
  AddCharset UTF-8 .html .htm .js .mjs .css .json .xml .txt .svg

  # Ensure module scripts/styles return expected MIME type
  AddType text/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType image/svg+xml .svg
</IfModule>

# Security + caching headers
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"

  Header always merge Vary "Accept-Encoding"
  Header unset ETag

  # Long cache for static assets
  <FilesMatch "\.(js|mjs|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|avif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # HTML should always be fresh
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Service worker should be fresh
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Manifest can be cached shorter
  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

FileETag None

# Runtime compression (safe, no forced .gz/.br rewrites)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  AddOutputFilterByType DEFLATE font/ttf font/otf font/opentype
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject

  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# SPA routing
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files/directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep SEO/system files accessible
  RewriteRule ^robots\.txt$ - [L]
  RewriteRule ^sitemap.*\.xml$ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>
