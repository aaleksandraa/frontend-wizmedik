# WizMedik Frontend SPA .htaccess (safe)

AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  # Normalize compressed extensions so .gz/.br are treated as encodings,
  # not as final MIME type (application/x-gzip).
  RemoveType .gz
  RemoveType .br
  AddEncoding gzip .gz
  AddEncoding br .br

  AddType text/html .html .html.gz .html.br
  AddType text/javascript .js .mjs
  AddType text/javascript .js.gz .mjs.gz .js.br .mjs.br
  AddType text/css .css .css.gz .css.br
  AddType application/json .json .json.gz .json.br
  AddType image/svg+xml .svg .svg.gz .svg.br
</IfModule>

<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(self), microphone=(), camera=()"

  Header set Vary "Accept-Encoding"
  Header unset ETag

  <FilesMatch "\.(js|mjs|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|avif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  <FilesMatch "^manifest\.json$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "^sitemap(?:-[A-Za-z0-9-]+)?\.xml$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

FileETag None

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  AddOutputFilterByType DEFLATE font/ttf font/otf font/opentype
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject

  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteOptions AllowNoSlash
  RewriteBase /

  # Always serve sitemap XML from backend app routes.
  # Prevents stale/missing static sitemap files on frontend host.
  RewriteRule ^sitemap(?:-[A-Za-z0-9-]+)?\.xml$ https://api.wizmedik.com/$0 [R=302,L,NC,NE]

  # Force legacy compressed asset URLs back to canonical files.
  # Prevents module load failures from stale HTML/SW caches referencing *.js.gz/*.js.br.
  RewriteRule ^assets/(.+)\.(js|mjs|css|json|svg)\.(gz|br)$ /assets/$1.$2 [R=302,L,NC]

  # Missing static assets must return 404 (never SPA index.html).
  RewriteCond %{REQUEST_URI} ^/assets/ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Missing sitemap files must return 404 (never SPA index.html).
  RewriteCond %{REQUEST_URI} ^/sitemap(?:-[A-Za-z0-9-]+)?\.xml$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Serve prerendered route directories without external 301 to trailing slash.
  # Example: /specijalnost/ginekologija/histeroskopija -> /.../index.html (internal)
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ $1/index.html [L]

  # Existing files/directories are served as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback to static SPA shell.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>
